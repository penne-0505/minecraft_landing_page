# Portfolio demo mode is enabled by default.
# Set both flags to false only when intentionally testing the real reference integrations.
DEMO_MODE=true
VITE_DEMO_MODE=true

# Cloudflare Pages Functions / Frontend shared
APP_BASE_URL=https://clover-support-demo.pages.dev
VITE_APP_BASE_URL=https://clover-support-demo.pages.dev
VITE_DISCORD_CLIENT_ID=123456789012345678
VITE_DISCORD_REDIRECT_URI=https://clover-support-demo.pages.dev/auth/callback
VITE_DISCORD_INVITE_URL=https://discord.gg/your_invite_here

# SEO / Social
VITE_SITE_NAME=Clover Support Demo
VITE_SITE_DESCRIPTION=Minecraft向けコミュニティ支援フローを題材にしたポートフォリオ用デモです。実際の取引、契約、ロール付与、公式提携は行いません。
VITE_SITE_OG_IMAGE=https://clover-support-demo.pages.dev/og-image-1200x630.webp
VITE_SITE_LOGO=https://clover-support-demo.pages.dev/logo.webp
VITE_SITE_TWITTER=
VITE_SITE_LOCALE=ja_JP
VITE_SITE_SOCIALS=

# Stripe reference integration (ignored while DEMO_MODE=true)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ONE_MONTH=price_one_month_xxx          # 1ヶ月のみ
STRIPE_PRICE_SUB_MONTHLY=price_sub_monthly_xxx      # 1ヶ月ごと更新
STRIPE_PRICE_SUB_YEARLY=price_sub_yearly_xxx        # 1年ごと更新

# Discord OAuth / Guild / Bot reference integration (ignored while DEMO_MODE=true)
DISCORD_CLIENT_ID=123456789012345678
DISCORD_CLIENT_SECRET=your_client_secret
DISCORD_REDIRECT_URI=https://clover-support-demo.pages.dev/auth/callback
DISCORD_GUILD_ID=123456789012345678
DISCORD_ROLE_MEMBER_ID=123456789012345678
DISCORD_BOT_TOKEN=bot_token_with_manage_roles
DISCORD_INVITE_URL=https://discord.gg/your_invite_here

# Observability (後日導入)
# Frontend (Vite) --- src/analytics.js が参照
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_SENTRY_DSN=https://xxxx.ingest.sentry.io/xxxx

# Functions (Cloudflare Pages Functions) --- functions/telemetry.js が参照
DEBUG_TELEMETRY=false
SENTRY_DSN=https://xxxx.ingest.sentry.io/xxxx

# GA4 Measurement Protocol (Functions 側で導入する場合に使用)
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=ga4_api_secret_if_needed
